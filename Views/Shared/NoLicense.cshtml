@{
    ViewData["Title"] = "Acceso Bloqueado";
}

<div class="d-flex align-items-center justify-content-center h-100 min-vh-50">
    <div class="text-center">
        <div class="mb-4">
            <i class="bi bi-shield-lock text-danger" style="font-size: 4rem;"></i>
        </div>
        <h2 class="mb-3">Suscripción o Licencia Requerida</h2>
        <p class="text-muted mb-4">No cuenta con una suscripción activa o licencia válida para acceder a este módulo del sistema.</p>
        
        <a asp-controller="Licencia" asp-action="Index" class="btn-erp-primary text-decoration-none">
            <i class="bi bi-key me-2"></i>Ir a Gestión de Licencia
        </a>
    </div>
</div>

<script>
    document.addEventListener('DOMContentLoaded', function() {
        if (typeof showNotification === 'function') {
            showNotification('Licencia Requerida', 'No tiene una suscripción o licencia válida activa.', 'danger');
        }
    });
</script>
