@model Sistema_Ferreteria.Models.ViewModels.VentasReporteVM
@using Sistema_Ferreteria.Services.ReportesVentas
@{
    ViewData["Title"] = "Reporte de Ventas";
    var inicioStr = Model.FechaInicio.ToString("yyyy-MM-dd");
    var finStr = Model.FechaFin.ToString("yyyy-MM-dd");
}

<div class="container-fluid">
    <div class="row mb-4">
        <div class="col-12 d-flex justify-content-between align-items-center">
            <h2 class="h3 mb-0 text-gray-800">Reporte Detallado de Ventas</h2>
            <nav aria-label="breadcrumb">
                <ol class="breadcrumb mb-0">
                    <li class="breadcrumb-item"><a asp-action="Index">Dashboard</a></li>
                    <li class="breadcrumb-item active" aria-current="page">Ventas</li>
                </ol>
            </nav>
        </div>
    </div>

    @if (!string.IsNullOrEmpty(Model.ValidationAlert))
    {
        <div class="alert alert-warning border-0 shadow-sm rounded-4 mb-4" role="alert">
            @Model.ValidationAlert
        </div>
    }

    <!-- Filtros -->
    <div class="card shadow-sm mb-4 border-0 rounded-4">
        <div class="card-body">
            <form method="get" class="row align-items-end g-3">
                <input type="hidden" name="page" value="1" />
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Fecha Inicio</label>
                    <input type="date" name="inicio" class="form-control" value="@inicioStr" />
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold">Fecha Fin</label>
                    <input type="date" name="fin" class="form-control" value="@finStr" />
                </div>
                <div class="col-md-2">
                    <label class="form-label small fw-bold">Por página</label>
                    <select name="pageSize" class="form-select">
                        @foreach (var opt in new[] { 25, 50, 100, 200 })
                        {
                            if (Model.PageSize == opt)
                            {
                                <option value="@opt" selected>@opt</option>
                            }
                            else
                            {
                                <option value="@opt">@opt</option>
                            }
                        }
                    </select>
                </div>
                <div class="col-md-4 d-flex gap-2">
                    <button type="submit" class="btn btn-primary w-100">
                        <i class="bi bi-filter"></i> Filtrar
                    </button>
                    <div class="dropdown">
                        <button class="btn btn-outline-success dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                            <i class="bi bi-download"></i> Exportar
                        </button>
                        <ul class="dropdown-menu dropdown-menu-end shadow border-0">
                            <li>
                                <a class="dropdown-item" asp-action="ExportarExcelVentas" asp-route-inicio="@inicioStr" asp-route-fin="@finStr">
                                    <i class="bi bi-file-earmark-excel me-2 text-success"></i> Excel (máx. @ReportesVentasLimits.MaxExcelExportRows.ToString("N0"))
                                </a>
                            </li>
                            <li>
                                <a class="dropdown-item" asp-action="ExportarPdfVentas" asp-route-inicio="@inicioStr" asp-route-fin="@finStr">
                                    <i class="bi bi-file-earmark-pdf me-2 text-danger"></i> PDF (máx. @ReportesVentasLimits.MaxPdfExportRows.ToString("N0") filas)
                                </a>
                            </li>
                            <li><hr class="dropdown-divider"></li>
                            <li>
                                <a class="dropdown-item" href="javascript:void(0)" onclick="window.print()">
                                    <i class="bi bi-printer me-2 text-primary"></i> Imprimir Rápido
                                </a>
                            </li>
                        </ul>
                    </div>
                </div>
            </form>
            <p class="text-muted small mb-0 mt-2">
                Rango máximo: <strong>@ReportesVentasLimits.MaxReportCalendarDays días</strong> calendario.
                Exportación Excel hasta <strong>@ReportesVentasLimits.MaxExcelExportRows.ToString("N0")</strong> filas; PDF hasta <strong>@ReportesVentasLimits.MaxPdfExportRows.ToString("N0")</strong> filas por archivo.
            </p>
        </div>
    </div>

    <!-- Resumen -->
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-primary text-white border-0 shadow-sm rounded-4">
                <div class="card-body py-3">
                    <p class="mb-0 small opacity-75">Total Vendido en el Periodo</p>
                    <h3 class="mb-0">C$ @Model.TotalVendido.ToString("N2")</h3>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-info text-white border-0 shadow-sm rounded-4">
                <div class="card-body py-3">
                    <p class="mb-0 small opacity-75">Total Facturas Generadas</p>
                    <h3 class="mb-0">@Model.TotalFacturas</h3>
                </div>
            </div>
        </div>
    </div>

    @if (Model.TotalRegistros > 0)
    {
        <p class="text-muted small mb-2 px-1">
            Mostrando <strong>@Model.RegistroInicio</strong>–<strong>@Model.RegistroFin</strong> de <strong>@Model.TotalRegistros</strong> facturas en el periodo.
            Los totales de las tarjetas incluyen todo el rango; la tabla muestra solo esta página.
        </p>
    }

    <!-- Tabla de Resultados -->
    <div class="card shadow-sm border-0 rounded-4">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="bg-light">
                        <tr>
                            <th class="ps-4">Factura</th>
                            <th>Fecha</th>
                            <th>Cliente</th>
                            <th class="text-end">Monto</th>
                            <th class="text-center">Estado</th>
                            <th class="text-center pe-4">Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model.Detalles)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@item.NumeroFactura</td>
                                <td class="small">@item.Fecha.ToLocalTime().ToString("dd/MM/yyyy HH:mm")</td>
                                <td>@item.Cliente</td>
                                <td class="text-end fw-bold">C$ @item.Total.ToString("N2")</td>
                                <td class="text-center">
                                    @{
                                        var badgeClass = item.Estado switch {
                                            "Completada" => "bg-success-subtle text-success",
                                            "Pendiente" => "bg-warning-subtle text-warning",
                                            "Anulada" => "bg-danger-subtle text-danger",
                                            _ => "bg-secondary-subtle text-secondary"
                                        };
                                    }
                                    <span class="badge @badgeClass rounded-pill">@item.Estado</span>
                                </td>
                                <td class="text-center pe-4">
                                    <button class="btn btn-link btn-sm text-primary" title="Ver Detalles">
                                        <i class="bi bi-eye"></i>
                                    </button>
                                </td>
                            </tr>
                        }
                        @if (!Model.Detalles.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-search fs-1 d-block mb-2"></i>
                                    No se encontraron ventas en este rango de fechas.
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
            @if (Model.TotalPages > 1)
            {
                <nav class="p-3 border-top d-flex flex-wrap justify-content-between align-items-center gap-2" aria-label="Paginación ventas">
                    <span class="text-muted small">Página @Model.Page de @Model.TotalPages</span>
                    <ul class="pagination pagination-sm mb-0">
                        <li class="page-item @(Model.Page <= 1 ? "disabled" : "")">
                            <a class="page-link" asp-action="Ventas" asp-route-inicio="@inicioStr" asp-route-fin="@finStr" asp-route-page="@(Model.Page - 1)" asp-route-pageSize="@Model.PageSize">Anterior</a>
                        </li>
                        <li class="page-item @(Model.Page >= Model.TotalPages ? "disabled" : "")">
                            <a class="page-link" asp-action="Ventas" asp-route-inicio="@inicioStr" asp-route-fin="@finStr" asp-route-page="@(Model.Page + 1)" asp-route-pageSize="@Model.PageSize">Siguiente</a>
                        </li>
                    </ul>
                </nav>
            }
        </div>
    </div>
</div>

<style>
    @@media print {
        .top-header, .sidebar, .card-header, form, .btn, .breadcrumb {
            display: none !important;
        }
        .main-content {
            margin-left: 0 !important;
            padding: 0 !important;
        }
        .card {
            box-shadow: none !important;
            border: 1px solid #ddd !important;
        }
    }
</style>
